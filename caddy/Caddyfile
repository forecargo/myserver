# Tailscale IPでHTTPSを終端（証明書は自己署名）
:80 {
    route /fudebako* {
        uri strip_prefix /fudebako
        root * /srv/fudebako
        file_server
    }

    route /ocr* {
        reverse_proxy ocr-api:8000
    }

    route /guideline* {
        uri strip_prefix /guideline
        reverse_proxy guideline-api:8001
    }

    route /schedule* {
        reverse_proxy ocr-api:8000
    }

    route /health {
        reverse_proxy ocr-api:8000
    }

    route /trouble/line/webhook {
        uri strip_prefix /trouble
        reverse_proxy trouble-api:8002
    }

    route /trouble/liff* {
        uri strip_prefix /trouble
        reverse_proxy trouble-api:8002
    }

    route /trouble* {
        basic_auth {
            ncbtrouble <REDACTED-ROTATED-HASH>
        }
        uri strip_prefix /trouble
        reverse_proxy trouble-api:8002
    }

    route /mermaid/assets* {
        uri strip_prefix /mermaid
        reverse_proxy mermaid-api:8004
    }

    route /mermaid* {
        basic_auth {
            ncbmermaid <REDACTED-ROTATED-HASH>
        }
        uri strip_prefix /mermaid
        reverse_proxy mermaid-api:8004 {
            flush_interval -1
        }
    }

    route /gpt-image* {
        basic_auth {
            ncbgpt <REDACTED-ROTATED-HASH>
        }
        uri strip_prefix /gpt-image
        reverse_proxy gpt-image:8003 {
            flush_interval -1
        }
    }
}
