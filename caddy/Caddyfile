# Tailscale IPでHTTPSを終端（証明書は自己署名）
:80 {
    route /ocr* {
        reverse_proxy ocr-api:8000
    }

    route /guideline* {
        uri strip_prefix /guideline
        reverse_proxy guideline-api:8001
    }

    route /schedule* {
        reverse_proxy ocr-api:8000
    }

    route /health {
        reverse_proxy ocr-api:8000
    }

    route /trouble/line/webhook {
        uri strip_prefix /trouble
        reverse_proxy trouble-api:8002
    }

    route /trouble* {
        basicauth {
            ncbtrouble $2a$14$dS9IP6W1Pz/clOpOGL5jx.ulO8QaVqN1wwoS7wJ/n4ee4gpWQPk4C
        }
        uri strip_prefix /trouble
        reverse_proxy trouble-api:8002
    }
}
